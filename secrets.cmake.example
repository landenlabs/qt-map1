# API key template – safe to commit.
# Copy this file to secrets.cmake and fill in your real values.
# secrets.cmake is listed in .gitignore and will never be committed.

set(SUN_API_KEY "your-sun-api-key-here")    # Weather Company / TWC tile API key
set(SUN_API_KEY_EXPIRY_DAYS 30)            # built-in key valid for this many days after compile
